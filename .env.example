# Copy to .env and fill in to go live. With everything blank the site still runs:
# it renders from the seed data in src/lib/data/projects.ts, the lead form logs
# to the console, and /api/sync-repos returns a dry run. This mirrors the
# zero-key fallback in chatbot-closer and GitDashboard.

# Supabase (public: safe to expose to the browser)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server only, NEVER exposed). Used by /api/sync-repos
# to write archive drafts.
SUPABASE_SERVICE_ROLE_KEY=

# Which GitHub account the archive syncs from
PUBLIC_GITHUB_USER=adxoxo

# Optional GitHub token (server only) to raise the sync rate limit
GITHUB_TOKEN=

# n8n webhook that receives a new lead (server only). Blank = log only.
N8N_LEAD_WEBHOOK=
